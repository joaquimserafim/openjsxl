{
	"name": "@openjsxl/core",
	"version": "0.6.0",
	"description": "Core OOXML engine for openjsxl — zero-dependency .xlsx primitives (zip, xml, cell typing, read + write).",
	"type": "module",
	"license": "MIT",
	"author": "joaquimserafim (https://github.com/joaquimserafim)",
	"homepage": "https://github.com/joaquimserafim/openjsxl#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/joaquimserafim/openjsxl.git",
		"directory": "packages/core"
	},
	"bugs": {
		"url": "https://github.com/joaquimserafim/openjsxl/issues"
	},
	"keywords": [
		"xlsx",
		"excel",
		"spreadsheet",
		"ooxml",
		"reader",
		"zip",
		"deflate"
	],
	"engines": {
		"node": ">=24"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"prepack": "tsup",
		"typecheck": "tsc -p tsconfig.json"
	},
	"devDependencies": {
		"@openjsxl/fixtures": "workspace:*"
	},
	"publishConfig": {
		"access": "public"
	}
}
